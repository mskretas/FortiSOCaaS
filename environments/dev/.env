# Docker compose build settings
COMPOSE_PROFILES=dev

# FortiCloud Auth settings
FORTICLOUD_AUTH_URL=http://fortiauth_demo:8000/api/v1/oauth/token/

# FortiNet SOCaaS settings
FORTINET_SOCAAS_URL=http://fortiauth_demo:8000
FORTINET_SOCAAS_ALLOW_INSECURE_HTTP=true
FORTINET_SOCAAS_API_ID=tel2
FORTINET_SOCAAS_PASSWORD=tel3
FORTINET_SOCAAS_CLIENT_ID=tel4
COLLECTOR_IP=syslog_demo
COLLECTOR_PORT=5514
